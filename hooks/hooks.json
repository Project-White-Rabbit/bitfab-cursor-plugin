{
  "version": 1,
  "hooks": {
    "SessionStart": [
      {
        "matcher": "startup",
        "hooks": [
          {
            "type": "command",
            "command": "${CURSOR_PLUGIN_ROOT}/scripts/session-start",
            "async": false
          }
        ]
      },
      {
        "matcher": "resume",
        "hooks": [
          {
            "type": "command",
            "command": "${CURSOR_PLUGIN_ROOT}/scripts/session-start",
            "async": false
          }
        ]
      }
    ]
  }
}
